# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
DEBUG=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: groq | gemini | openai
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=15.0

# ── API Keys (fill in only the one you use) ──────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ──────────────────────────────────────────────────────────────
# Path to your downloaded service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json
# Optionally restrict searches to a specific root folder ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_SESSION_HISTORY=20

# ── Search ────────────────────────────────────────────────────────────────────
MAX_DRIVE_RESULTS=50
DEFAULT_RESULT_LIMIT=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8501

# ── Redis (optional — leave blank to use in-memory session store) ─────────────
REDIS_URL=
